# ──────────────────────────────────────────────────────────────────────────────
# TrustStack Lite — environment configuration
# Copy to .env:  cp .env.example .env
# These are SAFE LOCAL PLACEHOLDERS ONLY. Never commit real secrets.
# External OCR/KYC credentials are intentionally blank: the system reports those
# dependencies as `not_configured` and the endpoints that need them return
# 424 Failed Dependency instead of faking success.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info
SERVICE_NAME=truststack-api

# ── Auth / crypto (CHANGE THESE FOR ANY SHARED ENVIRONMENT) ───────────────────
# Use at least 32 bytes (HS256). Generate with: openssl rand -base64 48
JWT_SECRET=change-me-local-jwt-secret-please-rotate-0123456789
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=truststack
POSTGRES_PASSWORD=truststack
POSTGRES_DB=truststack
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://truststack:truststack@postgres:5432/truststack
TEST_DATABASE_URL=postgresql+psycopg://truststack:truststack@postgres:5432/truststack_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── Object storage (MinIO locally, real S3 in cloud) ──────────────────────────
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=truststack
S3_SECRET_ACCESS_KEY=truststack-secret
S3_BUCKET=truststack-documents
S3_USE_PATH_STYLE=true
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── External OCR provider (OPTIONAL — leave blank to run without OCR) ──────────
# OCR_PROVIDER one of: aws_textract | google_vision | google_document_ai
# Leave blank to run without OCR (uploads then return 424 dependency_not_configured).
OCR_PROVIDER=
# -- aws_textract --
AWS_TEXTRACT_REGION=
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY come from the standard AWS env chain.
# -- google_vision --
GOOGLE_APPLICATION_CREDENTIALS=
# -- google_document_ai --
# Mount the service-account JSON at infra/secrets/ ; the container path is set in
# docker-compose to /secrets/google-docai.json.
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_CREDENTIALS=

# ── External KYC / liveness provider (OPTIONAL) ───────────────────────────────
# KYC_PROVIDER + KYC_API_URL + KYC_API_KEY are required together to mark KYC as
# configured. Supported provider: persona. Without these, verification endpoints
# return 424 missing_provider_config.
# KYC_PROVIDER=persona
# KYC_API_URL=https://withpersona.com/api/v1
KYC_PROVIDER=
KYC_API_KEY=
KYC_API_URL=
# Used to verify inbound provider webhook signatures (HMAC-SHA256).
KYC_WEBHOOK_SECRET=
# Provider inquiry/template id used when creating sessions.
KYC_TEMPLATE_ID=

# ── Webhooks ──────────────────────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=change-me-local-webhook-secret
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_BACKOFF_BASE_SECONDS=2
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_INITIAL_DISPATCH_DELAY_SECONDS=2
# Local webhook receiver container (echoes 200); used for demo/smoke deliveries.
WEBHOOK_RECEIVER_PORT=8888

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_APIKEY_PER_MINUTE=60

# ── Consent / privacy ─────────────────────────────────────────────────────────
DEFAULT_JURISDICTION=IN-DPDP
DEFAULT_LANGUAGES=en,hi

# ── Seed data (deterministic local accounts) ──────────────────────────────────
SEED_TENANT_NAME=Acme Onboarding
SEED_TENANT_SLUG=acme
SEED_ADMIN_EMAIL=admin@truststack.local
SEED_ADMIN_PASSWORD=change-me-local
SEED_ANALYST_EMAIL=analyst@truststack.local
SEED_ANALYST_PASSWORD=change-me-local

# ── Web ───────────────────────────────────────────────────────────────────────
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_SERVICE_NAME=truststack-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── CI / Testing ───────────────────────────────────────────────────────────────
CI=false
RUN_EXTERNAL_TESTS=false
MIN_BACKEND_COVERAGE=75
TRIVY_SEVERITY=HIGH,CRITICAL

# ── Cloud Deployment (Production Override) ─────────────────────────────────────
# Uncomment and configure for production deployment
# APP_ENV=production
# LOG_LEVEL=warning
# DATABASE_URL=postgresql://user:pass@rds-instance:5432/truststack
# REDIS_URL=redis://elasticache-endpoint:6379/0
# S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com
# S3_REGION=us-east-1
# S3_BUCKET=truststack-prod-documents
# JWT_SECRET=<rotate-this-256-bit-secret>
# WEBHOOK_DEFAULT_SECRET=<rotate-this-secret>
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
